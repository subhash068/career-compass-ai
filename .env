# Career Compass AI - Environment Configuration
# Copy this file as .env and customize as needed
# NEVER commit .env to version control!

# ========================================
# CORE AUTHENTICATION (REQUIRED)
# ========================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-use-at-least-32-random-chars-here-8XjK9pLmNqRsTuVwXyZ0123456789abcdef
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(64))"

# ========================================
# DATABASE (SQLite fallback - existing career_compass.db)
# ========================================
#DATABASE_URL_DEV=mysql+mysqlconnector://root:kali@localhost/career_compass
DATABASE_URL_DEV=sqlite:///./backend/career_compass.db
# MySQL= mysql+mysqlconnector://root:password@localhost/career_compass
# DATABASE_URL_TEST=sqlite:///career_compass_test.db
# ENVIRONMENT=development

# ========================================
# EMAIL (DISABLED for local dev - enable for production)
# ========================================
EMAIL_DISABLED=true
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@careercompass.ai

# ========================================
# AI SERVICES (Optional - defaults work)
# ========================================
# OPENAI_API_KEY=sk-...
# ENABLE_LLM=false
# LLM_MODEL=gpt-3.5-turbo

# ========================================
# CORS (Local development)
# ========================================
# CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# ========================================
# DEBUG & LOGGING
# ========================================
DEBUG=true
SQLALCHEMY_ECHO=false
