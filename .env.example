# Career Compass AI - Environment Configuration
# Copy this file to .env and update values for your environment

# Database
DATABASE_URL=mysql+mysqlconnector://root:kali@mysql:3306/career_compass
DATABASE_URL_DEV=mysql+mysqlconnector://root:kali@localhost/career_compass
# Optional explicit production URL override
# DATABASE_URL_PROD=mysql+mysqlconnector://user:password@host:3306/career_compass

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# Email Configuration (Development: set EMAIL_DISABLED=true to skip)
EMAIL_DISABLED=true

# OTP Configuration
# OTP length is clamped to 4..8 digits.
OTP_LENGTH=6
# OTP expiry in minutes is clamped to 1..60.
OTP_EXPIRY_MINUTES=10
# Optional fixed OTP for local testing only (do not use in production).
# OTP_FIXED_CODE=123456

# SMTP Settings (required when EMAIL_DISABLED=false)
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Career Compass <your-email@gmail.com>

# For production, use proper SMTP service like SendGrid, AWS SES, etc.

# ollama launch claude --model qwen3.5 
